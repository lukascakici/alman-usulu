# ======================================================================
# Supabase — https://supabase.com/dashboard > Project Settings > API
# ======================================================================
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# SADECE SUNUCU — client bundle'ına asla sızdırma.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# ======================================================================
# App
# ======================================================================

# QR token imzalamada kullanılacak HMAC secret (Faz B için). 32+ karakter.
# Üretmek için: openssl rand -hex 32
APP_QR_TOKEN_SECRET="degistir-32-karakterden-uzun-rastgele-bir-string-olsun"

# Dev'de http://localhost:3000, prod'da Vercel domaininiz.
APP_BASE_URL="http://localhost:3000"
